{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "self-web",
  "compatibility_date": "2026-05-09",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "."
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],

  // 静态资源目录（你原来的配置）
  "pages_build_output_dir": "./"
}